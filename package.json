{
  "name": "issue-dedup-action",
  "version": "0.1.0",
  "private": true,
  "description": "GitHub Action that detects duplicate issues using the Copilot SDK.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --format=cjs --target=node24 --outfile=dist/index.cjs",
    "typecheck": "tsc --noEmit",
    "test": "tsc --noEmit && node --experimental-strip-types --test src/*.test.ts"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@github/copilot-sdk": "^1.0.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "typescript": "^7.0.2"
  }
}
